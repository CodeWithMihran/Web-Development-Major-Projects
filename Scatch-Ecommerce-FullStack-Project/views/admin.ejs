<%- include('./partials/header') %>

    <div class="min-h-screen flex bg-neutral-100">
        <aside class="w-64 bg-black text-white p-8 hidden md:flex flex-col justify-between">

            <div>
                <h2 class="text-2xl font-bold mb-10 tracking-wide text-amber-400">
                    Cartify Admin
                </h2>

                <nav class="space-y-4 text-sm">
                    <a href="#" class="block hover:text-amber-400 transition">
                        All Products
                    </a>
                    <a href="#" class="block hover:text-amber-400 transition">
                        Create New Product
                    </a>
                </nav>
            </div>

            <a href="/logout"
                class="text-sm bg-amber-500 text-black px-4 py-2 rounded-full hover:bg-amber-600 transition text-center">
                Logout
            </a>

        </aside>
        <main class="flex-1 p-10">
            <div class="flex justify-between items-center mb-10">
                <h1 class="text-3xl font-semibold text-neutral-800">
                    Product Management
                </h1>
                <a href="#" class="text-red-500 hover:text-red-600 transition text-sm">
                    Delete All Products
                </a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

                <% for(let i=0; i < 8; i++) { %>
                    <div
                        class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition duration-300 group">
                        <div class="h-52 bg-neutral-200 flex items-center justify-center overflow-hidden">
                            <span class="text-neutral-400 text-sm">
                                Product Image
                            </span>
                        </div>
                        <div class="p-5 flex justify-between items-center">

                            <div>
                                <h3 class="font-semibold text-neutral-800 group-hover:text-amber-500 transition">
                                    Clinge Bag
                                </h3>
                                <p class="text-neutral-500 text-sm">
                                    ₹ 1200
                                </p>
                            </div>
                            <a href="#"
                                class="w-9 h-9 flex items-center justify-center rounded-full bg-amber-500 text-black hover:bg-amber-600 transition shadow-md">
                                +
                            </a>
                        </div>
                    </div>
                    <% } %>
            </div>
        </main>
    </div>
    <%- include('./partials/footer') %>