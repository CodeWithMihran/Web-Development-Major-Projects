<%- include('./partials/header') %>
<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-500">
    <div class="bg-white/20 backdrop-blur-xl shadow-2xl rounded-3xl p-12 w-[400px] border border-white/30">
        <h1 class="text-3xl font-extrabold text-white text-center mb-2 tracking-wide">
            Cartify Admin
        </h1>
        <p class="text-white/80 text-center mb-8">
            Secure Admin Access
        </p>
        <form action="/create" method="post" class="space-y-5">
            <div>
                <input 
                    class="w-full px-4 py-3 rounded-xl bg-white/30 text-white placeholder-white/70 border border-white/40 focus:outline-none focus:ring-2 focus:ring-white transition"
                    type="email" 
                    placeholder="Enter Email"
                    name="email"
                    required>
            </div>
            <div>
                <input 
                    class="w-full px-4 py-3 rounded-xl bg-white/30 text-white placeholder-white/70 border border-white/40 focus:outline-none focus:ring-2 focus:ring-white transition"
                    type="password" 
                    placeholder="Enter Password"
                    name="password"
                    required>
            </div>
            <button 
                class="w-full py-3 rounded-xl bg-white text-indigo-600 font-semibold text-lg shadow-lg hover:scale-105 hover:shadow-2xl transition-all duration-300">
                🔐 Login
            </button>
        </form>
    </div>
</div>
<%- include('./partials/footer') %>