<%- include('./partials/header') %>

    <% if(success.length>0){ %>
        <div class="fixed top-6 left-1/2 -translate-x-1/2 px-6 py-3 rounded-xl bg-emerald-500 shadow-lg">
            <span class="text-white font-medium">
                <%= success %>
            </span>
        </div>
        <% } %>
            <div class="min-h-screen bg-gradient-to-br from-indigo-50 via-purple-50 to-pink-50 flex">
                <aside class="w-64 bg-white/70 backdrop-blur-lg shadow-xl p-8 border-r border-gray-200">
                    <h1 class="text-2xl font-extrabold text-indigo-600 mb-8 tracking-wide">
                        Cartify Admin
                    </h1>
                    <nav class="flex flex-col space-y-4 text-gray-700 font-medium">
                        <a href="/products"
                            class="hover:text-indigo-600 hover:translate-x-1 transition-all duration-200">
                            📦 All Products
                        </a>
                        <a href="/products/create" class="text-indigo-600 font-semibold">
                            ➕ Create Product
                        </a>
                    </nav>
                </aside>
                <main class="flex-1 p-12">
                    <div
                        class="max-w-3xl mx-auto bg-white/80 backdrop-blur-xl shadow-2xl rounded-3xl p-10 border border-gray-100">
                        <h2 class="text-3xl font-bold text-gray-800 mb-8">
                            Create New Product
                        </h2>
                        <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data"
                            class="space-y-8">
                            <div>
                                <h3 class="text-lg font-semibold text-indigo-600 mb-4">
                                    Product Details
                                </h3>
                                <div class="mb-6">
                                    <label class="block mb-2 text-gray-600 font-medium">
                                        Product Image
                                    </label>
                                    <input name="image" type="file"
                                        class="w-full p-3 border border-gray-200 rounded-xl bg-gray-50 focus:ring-2 focus:ring-indigo-400 focus:outline-none transition">
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <input name="name" type="text" placeholder="Product Name"
                                        class="p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-400 focus:outline-none transition">
                                    <input name="price" type="number" placeholder="Product Price"
                                        class="p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-400 focus:outline-none transition">
                                    <input name="discount" type="number" placeholder="Discount Price"
                                        class="p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-400 focus:outline-none transition">
                                </div>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-indigo-600 mb-4">
                                    Panel Styling
                                </h3>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                    <input name="bgcolor" type="text" placeholder="Background Color (e.g. #f3f4f6)"
                                        class="p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-pink-400 focus:outline-none transition">
                                    <input name="panelcolor" type="text" placeholder="Panel Color"
                                        class="p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-pink-400 focus:outline-none transition">
                                    <input name="textcolor" type="text" placeholder="Text Color"
                                        class="p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-pink-400 focus:outline-none transition">
                                </div>
                            </div>
                            <div>
                                <button type="submit"
                                    class="w-full py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-semibold text-lg shadow-lg hover:scale-105 hover:shadow-2xl transition-all duration-300">
                                    🚀 Create Product
                                </button>
                            </div>
                        </form>
                    </div>
                </main>
            </div>
<%- include('./partials/footer') %>