<%- include('./partials/header') %>

    <% if(success && success.length> 0){ %>
        <div class="fixed top-6 left-1/2 -translate-x-1/2 px-6 py-3 rounded-xl bg-emerald-500 shadow-lg">
            <span class="text-white font-medium">
                <%= success %>
            </span>
        </div>
        <% } %>
            <div class="min-h-screen bg-gradient-to-br from-indigo-50 via-purple-50 to-pink-50 flex px-16 py-12 gap-10">
                <aside class="w-64 bg-white shadow-xl rounded-2xl p-6 h-fit">

                    <div class="mb-8">
                        <h3 class="font-bold text-lg text-indigo-600 mb-3">Sort By</h3>
                        <form action="/shop">
                            <select name="sortby"
                                class="w-full border border-gray-200 px-3 py-2 rounded-lg focus:ring-2 focus:ring-indigo-400 focus:outline-none">
                                <option value="popular">Popular</option>
                                <option value="newest">Newest</option>
                            </select>
                        </form>
                    </div>
                    <div class="mb-10">
                        <h3 class="font-bold text-lg text-indigo-600 mb-3">Collections</h3>
                        <div class="flex flex-col gap-2 text-gray-600">
                            <a class="hover:text-indigo-600 transition cursor-pointer">New Collection</a>
                            <a class="hover:text-indigo-600 transition cursor-pointer">All Products</a>
                            <a class="hover:text-indigo-600 transition cursor-pointer">Discounted Products</a>
                        </div>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg text-indigo-600 mb-3">Filters</h3>
                        <div class="flex flex-col gap-2 text-gray-600">
                            <a class="hover:text-indigo-600 transition cursor-pointer">Availability</a>
                            <a class="hover:text-indigo-600 transition cursor-pointer">Discount</a>
                        </div>
                    </div>

                </aside>
                <main class="flex-1">

                    <h1 class="text-3xl font-bold text-gray-800 mb-8">
                        Explore Our Bags
                    </h1>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">

                        <% products.forEach(function(product){ %>

                            <div
                                class="bg-white rounded-2xl shadow-md hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 overflow-hidden">
                                <div class="h-56 flex items-center justify-center"
                                    style="background-color: <%= product.bgcolor %>">
                                    <img class="h-40 object-contain transition-transform duration-300 hover:scale-110"
                                        src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
                                </div>
                                <div class="p-5"
                                    style="background-color: <%= product.panelcolor %> color: <%= product.textcolor %>">

                                    <h3 class="font-semibold text-lg mb-2">
                                        <%= product.name %>
                                    </h3>
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <% if(product.discount && product.discount> 0){ %>
                                                <p class="text-sm line-through opacity-70">
                                                    ₹ <%= product.price %>
                                                </p>
                                                <p class="text-lg font-bold text-emerald-600">
                                                    ₹ <%= product.price - product.discount %>
                                                </p>
                                                <% } else { %>
                                                    <p class="text-lg font-bold">
                                                        ₹ <%= product.price %>
                                                    </p>
                                                    <% } %>
                                        </div>
                                        <a href="/addtocart/<%=product._id%>"
                                            class="w-10 h-10 flex items-center justify-center rounded-full bg-indigo-600 text-white hover:bg-indigo-700 transition shadow-md text-xl font-bold">
                                            +
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </main>
            </div>
            <%- include('./partials/footer') %>