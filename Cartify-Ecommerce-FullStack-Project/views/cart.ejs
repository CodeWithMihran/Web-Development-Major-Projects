<%- include('./partials/header') %>
    <% if (user.cart.length===0) { %>
        <div class="w-full h-screen flex items-center justify-center">
            <h2 class="text-2xl font-semibold">Your Cart is Empty 🛒</h2>
        </div>
        <% } else { %>
            <div class="w-full min-h-screen px-20 py-20">
                <% user.cart.forEach(function(item){ %>
                    <div class="w-full flex items-start gap-10 mb-16">
                        <div class="w-[30%] rounded-md overflow-hidden shadow-lg">
                            <div class="w-full h-80 flex justify-center items-center bg-[<%= item.bgcolor %>]">
                                <img class="h-[18rem]" src="data:image/jpeg;base64,<%= item.image.toString('base64') %>"
                                    alt="product">
                            </div>
                            <div class="w-full flex justify-between px-5 py-4 bg-[<%= item.panelcolor %>]">
                                <h3 class="text-2xl">
                                    <%= item.name %>
                                </h3>
                                <div class="px-3 py-1 rounded-md bg-white text-black">01</div>
                            </div>
                            <div
                                class="flex text-white items-center justify-between px-5 py-3 bg-[<%= item.textcolor %>]">
                                <h4 class="text-lg">Net Total</h4>
                                <h2 class="text-lg">
                                    ₹ <%= Number(item.price) - Number(item.discount) + 20 %>
                                </h2>
                            </div>
                        </div>
                        <div class="w-[70%]">
                            <h3 class="text-xl font-semibold">Price Breakdown</h3>
                            <div class="px-10 mt-5">
                                <div class="flex mt-2">
                                    <h4 class="w-1/3">Total MRP</h4>
                                    <h4>₹ <%= item.price %>
                                    </h4>
                                </div>
                                <div class="flex mt-2">
                                    <h4 class="w-1/3">Discount on MRP</h4>
                                    <h4>₹ <%= item.discount %>
                                    </h4>
                                </div>
                                <div class="flex mt-2">
                                    <h4 class="w-1/3">Platform Fee</h4>
                                    <h4>₹ 20</h4>
                                </div>
                                <div class="flex mt-2">
                                    <h4 class="w-1/3">Shipping Fee</h4>
                                    <h4>FREE</h4>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <div class="w-full h-[1px] bg-black mt-10"></div>
                        <div class="flex mt-8">
                            <h3 class="w-1/3 text-xl font-semibold">Total Cart Amount</h3>
                            <h3 class="font-semibold text-xl text-green-600">
                                ₹ <%= cartTotal %>
                            </h3>
                        </div>
            </div>
            <% } %>
                <%- include('./partials/footer') %>